# Quantyval AI - Environment Variables
# Copy to .env and fill in your values

# API Key for LLM (required)
QUANTYVAL_API_KEY=

# LLM Provider (kilocode, openai, anthropic, openrouter)
LLM_PROVIDER=kilocode

# Model to use
LLM_MODEL=kilo-auto/free

# Server
PORT=3000
HOST=0.0.0.0

# Telegram Bot (optional)
# TELEGRAM_BOT_TOKEN=

# Discord Bot (optional)
# DISCORD_BOT_TOKEN=
# DISCORD_APP_ID=

# Redis for memory cache (optional)
# REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=info